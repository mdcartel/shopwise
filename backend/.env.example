# 🦉 ShopWise Backend: Environment Variables

PORT=8080

# Your Alibaba Cloud DashScope compatible API key
QWEN_API_KEY=your_dashscope_api_key_here

# Alibaba Cloud DashScope Base URL (compatible mode)
# International: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Mainland China: https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

